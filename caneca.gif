center !important;}body .lg-flex-align-flex-start{justify-content:flex-start !important;}body .lg-flex-align-flex-end{justify-content:flex-end !important;}body .lg-mx-auto{margin-left:auto !important;margin-right:auto !important;}body .lg-ml-auto{margin-left:auto !important;}body .lg-mr-auto{margin-right:auto !important;}body .fusion-absolute-position-large{position:absolute;top:auto;width:100%;}.awb-sticky.awb-sticky-large{ position: sticky; top: var(--awb-sticky-offset,0); }}</style><style>.wp-block-gallery.is-cropped .blocks-gallery-item picture{height:100%;width:100%;}</style><style id="fusion-stylesheet-custom-css" type="text/css">@media only screen and (max-width: 530px) {
    .first-column {
      margin-right: 0 !important;
    }
  }
@media only screen and (max-width: 899px) {.fusion-mobile-menu-design-classic.fusion-header-v1 .fusion-header{min-height: 182px;}}
@media only screen and (max-width: 9999px) {.fusion-header{max-height: 92px;}}

.tw-clmns {
display: flex; flex-wrap: wrap;
}
.first-column{
    flex: 1; min-width: 250px; margin-right: 30px;
}
.twt-clmn{
flex: 1; min-width: 250px;
}
.fusion-mobile-menu-icons a {
    font-size: 30px;
    padding-top: 10px;
    padding-bottom: 10px;
}
.fusion-icon {
    text-decoration: none !important;
}
html:not(.avada-has-site-width-percent) #main{
    padding-left: 10px;
    padding-right: 10px;
    padding-top: 10px;
}
.awb-menu_row .menu-text {
    margin:2px;
    border-radius:3px;
}
.fusion-megamenu-bullet:before {
    content: "";
}
.fusion-main-menu-search-overlay .fusion-main-menu>.fusion-overlay-search {
    left: 110%;
}
.yarpp-thumbnail {
   height: 150px !important; 
}
.fusion-mobile-menu-search {
    background: #ffffff;
    padding: 9px;
}
.wp-caption-text {
    padding-top: 3px;
    padding-bottom: 3px;
    text-align: initial;
}

.wp-caption {
    position: relative;
    border: 1px solid #5b5b5b;
    background: #ebebeb;
    margin-bottom: 30px;
    border-radius: 0px 0px 5px 5px;
}
.wp-caption p {
	padding: 10px;
	margin: 0;
}
.yarpp-related {
    text-align: center;
}
.yarpp-thumbnail img {
    aspect-ratio: 4/3;
}
.yarpp-thumbnail > img, .yarpp-thumbnail-default {
    height: 90px !important;
}
.yarpp-thumbnail-title {
    text-align:center;
}
.post {
    margin-bottom: 10px;
}
.fusion-post-wrapper {
border-radius: 0px 0px 7px 7px;
}
.gsc-input {
    color: #747474 !important;
}
.fusion-theme-sharing-box .fusion-social-networks-wrapper {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    flex-direction: row-reverse;
}
blockquote{margin-left: 20px;margin-right: 20px;}
.fusion-blog-layout-grid .fusion-post-wrapper .fusion-image-wrapper img {
    aspect-ratio: 4/3;
}
.fusion-theme-sharing-box.fusion-sharing-box {
    margin-top: 25px;
    padding-bottom: 10px;
}</style>		<script type="text/javascript">
